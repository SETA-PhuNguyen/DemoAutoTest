{
  "name": "bookcart-playwright-tests",
  "version": "1.0.0",
  "description": "Automated testing suite for BookCart application using TypeScript and Playwright",
  "main": "index.js",
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test",
    "test:headed": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --headed",
    "test:chromium": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --project=chromium",
    "test:firefox": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --project=firefox",
    "test:webkit": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --project=webkit",
    "test:debug": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --debug",
    "test:ui": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --ui",
    "test:bdd": "cucumber-js features/*.feature --require-module ts-node/register --require features/support/**/*.ts --require features/step-definitions/**/*.ts",
    "test:bdd:smoke": "cucumber-js features/*.feature --require-module ts-node/register --require features/support/**/*.ts --require features/step-definitions/**/*.ts --tags @smoke",
    "test:bdd:e2e": "cucumber-js features/*.feature --require-module ts-node/register --require features/support/**/*.ts --require features/step-definitions/**/*.ts --tags @e2e",
    "test:bdd:login": "cucumber-js features/*.feature --require-module ts-node/register --require features/support/**/*.ts --require features/step-definitions/**/*.ts --tags @login",
    "test:bdd:search": "cucumber-js features/*.feature --require-module ts-node/register --require features/support/**/*.ts --require features/step-definitions/**/*.ts --tags @search",
    "test:bdd:cart": "cucumber-js features/*.feature --require-module ts-node/register --require features/support/**/*.ts --require features/step-definitions/**/*.ts --tags @cart",
    "test:bdd:api": "cucumber-js features/api.feature --require-module ts-node/register --require features/support/**/*.ts --require features/step-definitions/**/*.ts --tags @api",
    "test:bdd:api:smoke": "cucumber-js features/api.feature --require-module ts-node/register --require features/support/**/*.ts --require features/step-definitions/**/*.ts --tags '@api and @smoke'",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:clean": "rimraf allure-results allure-report",
    "test:allure": "npm test && npm run allure:generate",
    "codegen": "playwright codegen https://localhost:53424"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing",
    "e2e"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^7.3.2",
    "@cucumber/playwright": "^3.1.0",
    "@playwright/test": "^1.61.0",
    "@types/mssql": "^12.3.0",
    "@types/node": "^25.9.3",
    "allure-commandline": "^2.42.1",
    "allure-playwright": "^3.10.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "mssql": "^11.0.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}

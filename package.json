{
  "name": "bookcart-playwright-tests",
  "version": "1.0.0",
  "description": "Automated testing suite for BookCart application using TypeScript and Playwright",
  "main": "index.js",
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test",
    "test:headed": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --headed",
    "test:chromium": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --project=chromium",
    "test:firefox": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --project=firefox",
    "test:webkit": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --project=webkit",
    "test:debug": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --debug",
    "test:ui": "cross-env NODE_OPTIONS=--no-experimental-detect-module playwright test --ui",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://bookcart.azurewebsites.net"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing",
    "e2e"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3"
  }
}
